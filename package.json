{
  "name": "@nuxtjs/mcp-toolkit-monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt-modules/mcp-toolkit.git"
  },
  "author": "Hugo Richard <hugo.richard@vercel.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --filter=@nuxtjs/mcp-toolkit-playground",
    "dev:starter": "turbo run dev --filter=@nuxtjs/mcp-toolkit-starter",
    "dev:prepare": "turbo run dev:prepare",
    "dev:docs": "turbo run dev --filter=@nuxtjs/mcp-toolkit-docs",
    "build": "turbo run build",
    "build:module": "turbo run build --filter=@nuxtjs/mcp-toolkit",
    "build:docs": "turbo run build --filter=@nuxtjs/mcp-toolkit-docs",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:docs": "turbo run lint --filter=@nuxtjs/mcp-toolkit-docs",
    "test": "turbo run test --filter=@nuxtjs/mcp-toolkit",
    "typecheck": "turbo run typecheck",
    "typecheck:docs": "turbo run typecheck --filter=@nuxtjs/mcp-toolkit-docs",
    "eval": "turbo run eval --filter=@nuxtjs/mcp-toolkit-docs",
    "eval:ui": "turbo run eval:ui --filter=@nuxtjs/mcp-toolkit-docs",
    "clean": "turbo run clean",
    "automd": "npx automd --config .github/automd.json",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter=@nuxtjs/mcp-toolkit && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@nuxt/eslint-config": "^1.15.2",
    "eslint": "^9.39.4",
    "turbo": "^2.9.6",
    "typescript": "~6.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "@nuxtjs/mcp-toolkit": "workspace:*"
    }
  }
}
